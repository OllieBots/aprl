# Server
PORT=3001
NODE_ENV=development

# Set this in Vercel environment variables to point at your deployed backend
# Leave blank for local dev (Vite proxy handles /api -> localhost:3001)
VITE_API_URL=https://your-backend.up.railway.app

# CORS: set to your Vercel frontend URL so the backend accepts requests from it
CLIENT_URL=https://your-app.vercel.app

# iRacing (stored in DB after first setup, but can seed here for dev)
IRACING_EMAIL=
IRACING_PASSWORD=
IRACING_LEAGUE_ID=

# Discord
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# Security
COOKIE_SECRET=change_this_to_a_random_string_32chars
ENCRYPTION_KEY=change_this_to_a_random_32char_key
